---
interface Props {
  title: string;
  description: string;
  locale: 'ru' | 'en';
}

const { title, description, locale } = Astro.props;
---

<section class="hero">
  <div class="panel">
    <p class="eyebrow">{locale === 'ru' ? 'Главная страница' : 'Home page'}</p>
    <h1>{title}</h1>
    <p class="description">{description}</p>
  </div>
</section>

<style>
  .hero {
    display: grid;
    place-items: center;
    padding: 4rem 1.5rem 5rem;
  }

  .panel {
    width: min(100%, 720px);
    padding: 3rem;
    border: 1px solid rgba(29, 27, 24, 0.12);
    border-radius: 2rem;
    background: rgba(255, 252, 247, 0.82);
    box-shadow: 0 18px 60px rgba(78, 55, 19, 0.08);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #7a5c2b;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 8vw, 5rem);
    line-height: 0.95;
  }

  .description {
    max-width: 36rem;
    margin: 1.25rem 0 0;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(29, 27, 24, 0.78);
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 2.5rem;
    }

    .panel {
      padding: 2rem 1.25rem;
      border-radius: 1.5rem;
    }
  }
</style>
