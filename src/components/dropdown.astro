---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["_dropdown", className]}>
  <slot name="trigger" />

  <div class="_dropdown__bg"></div>
  <div class="_dropdown__body">
    <slot />
  </div>
</div>

<style>
  ._dropdown {
    position: relative;
  }

  ._dropdown__bg {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 20;
    display: none;
    width: 100%;
    height: 100vh;
  }

  ._dropdown__bg.active {
    display: block;
  }

  ._dropdown__body {
    position: absolute;
    top: calc(100% + 4px);
    right: -4px;
    z-index: 21;
    display: none;
    overflow: hidden;
    padding: 4px 0;
    border-radius: 4px;
    background: var(--bg-color);
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.4);
    opacity: 0;
    transform: translateY(-10px);
    transition:
      opacity var(--delay) ease-in-out,
      transform var(--delay) ease-in-out;
  }

  ._dropdown__body.active {
    display: block;
  }

  ._dropdown__body.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
