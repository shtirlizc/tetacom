---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  title?: string;
  locale?: 'ru' | 'en';
}

const { title = 'Tetacom', locale = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' } = Astro.props;
const nextLocale = locale === 'ru' ? 'en' : 'ru';
const switchHref = getRelativeLocaleUrl(nextLocale, '');
const switchLabel = locale === 'ru' ? 'English' : 'Русский';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={getRelativeLocaleUrl(locale, '')}>Tetacom</a>
      <nav aria-label={locale === 'ru' ? 'Переключение языка' : 'Language switcher'}>
        <a class="lang-switch" href={switchHref}>{switchLabel}</a>
      </nav>
    </header>
    <main class="page">
      <slot />
    </main>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: light;
    font-family: "Avenir Next", "Segoe UI", sans-serif;
    background: #f5efe6;
    color: #1d1b18;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  body {
    background:
      radial-gradient(circle at top left, rgba(204, 145, 58, 0.22), transparent 28%),
      linear-gradient(180deg, #f7f3ed 0%, #efe6db 100%);
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem 0;
  }

  .brand,
  .lang-switch {
    color: inherit;
    text-decoration: none;
  }

  .brand {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(29, 27, 24, 0.16);
    border-radius: 999px;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 255, 255, 0.65);
    font-size: 0.95rem;
    backdrop-filter: blur(8px);
  }

  .page {
    min-height: calc(100vh - 4.5rem);
  }
</style>
