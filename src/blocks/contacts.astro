      en: "OPZ Simulator User Guide",
    },
  },
  {
    href: withBase("files/guide-SP.pdf"),
    labels: {
      ru: "Руководство пользователя Программного комплекса",
      en: "Software Package User Guide",
    },
    titles: {
      ru: "Руководство пользователя Программного комплекса",
      en: "Software Package User Guide",
    },
  },
  {
    href: withBase(
      "files/%D0%9E%D0%BF%D0%B8%D1%81%D0%B0%D0%BD%D0%B8%D0%B5_%D1%84%D1%83%D0%BD%D0%BA%D1%86%D0%B8%D0%BE%D0%BD%D0%B0%D0%BB%D1%8C%D0%BD%D1%8B%D1%85_%D1%85%D0%B0%D1%80%D0%B0%D0%BA%D1%82%D0%B5%D1%80%D0%B8%D1%81%D1%82%D0%B8%D0%BA.pdf",
